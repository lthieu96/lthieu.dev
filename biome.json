{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		},
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useImportType": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "warn"
			}
		}
	},
	"overrides": [
		{
			"include": ["**/*.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noDoubleEquals": "off",
						"noArrayIndexKey": "warn"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"a11y": {
						"noRedundantRoles": "warn"
					}
				}
			}
		},
		{
			"include": ["**/common/decorators/cache-method.decorator.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	],
	"files": {
		"ignore": [
			"node_modules",
			"dist",
			".next",
			".expo",
			".turbo",
			"ios",
			"android"
		]
	}
}
